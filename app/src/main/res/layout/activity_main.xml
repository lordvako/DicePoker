<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark">

    <!-- Header -->
    <androidx.cardview.widget.CardView
        android:id="@+id/headerCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="12dp"
        app:cardBackgroundColor="@color/bg_card"
        app:cardCornerRadius="16dp"
        app:cardElevation="8dp"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🎲 ПОКЕР НА КУБИКАХ"
                android:textColor="@color/accent_gold"
                android:textSize="24sp"
                android:textStyle="bold"
                android:layout_gravity="center"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="12dp"
                android:gravity="center">

                <TextView
                    android:id="@+id/tvRound"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Раунд: 1/13"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp"
                    android:layout_marginEnd="24dp"/>

                <TextView
                    android:id="@+id/tvRollCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Бросок: 1/3"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp"
                    android:layout_marginEnd="24dp"/>

                <TextView
                    android:id="@+id/tvTotalScore"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Очки: 0"
                    android:textColor="@color/accent_gold"
                    android:textSize="18sp"
                    android:textStyle="bold"/>
            </LinearLayout>

            <TextView
                android:id="@+id/tvPhase"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Фаза 1: Собери цифры"
                android:textColor="@color/accent_blue"
                android:textSize="14sp"
                android:layout_gravity="center"
                android:layout_marginTop="8dp"/>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Dice Area -->
    <androidx.cardview.widget.CardView
        android:id="@+id/diceCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="12dp"
        app:cardBackgroundColor="@color/bg_card"
        app:cardCornerRadius="16dp"
        app:cardElevation="8dp"
        app:layout_constraintTop_toBottomOf="@id/headerCard">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Нажми на кубик, чтобы сохранить"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:layout_gravity="center"
                android:layout_marginBottom="8dp"/>

            <LinearLayout
                android:id="@+id/diceContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginBottom="16dp">

                <FrameLayout
                    android:id="@+id/dice1"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:layout_margin="4dp"
                    android:background="@drawable/bg_dice"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:id="@+id/ivDice1"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:layout_gravity="center"
                        android:src="@drawable/dice_1"/>
                </FrameLayout>

                <FrameLayout
                    android:id="@+id/dice2"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:layout_margin="4dp"
                    android:background="@drawable/bg_dice"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:id="@+id/ivDice2"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:layout_gravity="center"
                        android:src="@drawable/dice_1"/>
                </FrameLayout>

                <FrameLayout
                    android:id="@+id/dice3"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:layout_margin="4dp"
                    android:background="@drawable/bg_dice"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:id="@+id/ivDice3"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:layout_gravity="center"
                        android:src="@drawable/dice_1"/>
                </FrameLayout>

                <FrameLayout
                    android:id="@+id/dice4"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:layout_margin="4dp"
                    android:background="@drawable/bg_dice"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:id="@+id/ivDice4"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:layout_gravity="center"
                        android:src="@drawable/dice_1"/>
                </FrameLayout>

                <FrameLayout
                    android:id="@+id/dice5"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:layout_margin="4dp"
                    android:background="@drawable/bg_dice"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:id="@+id/ivDice5"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:layout_gravity="center"
                        android:src="@drawable/dice_1"/>
                </FrameLayout>
            </LinearLayout>

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnRoll"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="🎲 БРОСИТЬ КУБИКИ"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/black"
                android:background="@drawable/bg_button_roll"
                android:layout_gravity="center"/>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Score Table -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_margin="12dp"
        app:layout_constraintTop_toBottomOf="@id/diceCard"
        app:layout_constraintBottom_toTopOf="@id/bottomPanel">

        <LinearLayout
            android:id="@+id/scoreContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔢 ЦИФРЫ"
                android:textColor="@color/accent_blue"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp"/>

            <LinearLayout
                android:id="@+id/numbersContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🃏 КОМБИНАЦИИ"
                android:textColor="@color/accent_gold"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="8dp"/>

            <LinearLayout
                android:id="@+id/combinationsContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"/>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Bottom Panel -->
    <LinearLayout
        android:id="@+id/bottomPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/bg_card"
        android:padding="12dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <TextView
            android:id="@+id/tvMessage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Нажми 'БРОСИТЬ КУБИКИ' чтобы начать!"
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:layout_gravity="center"
            android:layout_marginBottom="8dp"/>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnNewGame"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="🔄 НОВАЯ ИГРА"
            android:textSize="16sp"
            android:textColor="@color/white"
            android:background="@drawable/bg_button_disabled"
            android:visibility="gone"/>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
